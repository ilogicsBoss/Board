# Default text handling
* text=auto

# Source and documentation files use LF in the repository
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.ino text eol=lf
*.S text eol=lf
*.s text eol=lf
*.md text eol=lf
*.adoc text eol=lf
*.txt text eol=lf
*.properties text eol=lf
*.conf text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.hex text eol=lf
Makefile text eol=lf
makeall text eol=lf
omake text eol=lf

# Windows command scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary artifacts and reference documents
*.pdf binary
*.PDF binary
*.zip binary
*.exe binary
*.dll binary
*.sys binary
*.a binary
*.o binary
*.elf binary
*.bin binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
